# Backend environment variables
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/varlexa
JWT_SECRET=replace-with-a-secret

# Frontend URL allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# Contact and booking email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
MAIL_FROM=Varlexa AI <your-email@example.com>
RECEIVER_EMAIL=admin@example.com
ADMIN_EMAIL=admin@example.com

# Google OAuth / Calendar API
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/bookings/google/callback
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_CALENDAR_ID=xxxxxxxxxxxxxxxxxxxxxxxxx
